# Adaptive Mock Interviewer — copy to .env.local and fill in.
# The app boots without these; routes that need a missing service return 503 with a
# clear message, and prepare()/score() fall back to an in-memory cache when Supabase
# is absent. Provide all three for the full live flow.

# --- OpenRouter (interviewer brain: plan-gen, live LLM, scoring) ---
OPENROUTER_API_KEY=
# Any OpenRouter model id. Haiku is fast + reliable for structured output (good for
# live demos). Swap to anthropic/claude-sonnet-4.6 for deeper interviews if you can
# accept slower plan generation.
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# --- ElevenLabs (voice runtime) ---
ELEVENLABS_API_KEY=
# Create a Conversational AI agent in the ElevenLabs dashboard, set its Custom LLM to
# OpenRouter (server URL https://openrouter.ai/api/v1, model = OPENROUTER_MODEL,
# secret OPENAI_API_KEY = your OpenRouter key), enable "overrides" for system prompt +
# first message, then paste the agent id here.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# --- Supabase (persistence + anonymous auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Simli avatar (OPTIONAL, experimental — gives the voice interviewer a face) ---
# Both required to turn the avatar on. Get an API key + create a face at simli.com.
# When set, voice interviews use websocket mode and render a lip-synced avatar.
SIMLI_API_KEY=
SIMLI_FACE_ID=

# --- Auth: uses the existing NEXT_PUBLIC_SUPABASE_* + enable Google in Supabase Auth ---
# --- Cashfree (payments) ---
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=
CASHFREE_ENV=sandbox
# --- Upstash Redis (durable rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
FREE_TEXT_DAILY_CAP=5
